generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum FamilyRole {
  OWNER
  ADMIN
  MEMBER
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

// ─── User ─────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  role      Role     @default(USER)
  firstName String?
  lastName  String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  familyMembers    FamilyMember[]
  createdTemplates Template[]
  receipts         Receipt[]
  savingsDeposits  SavingsDeposit[]
  createdEvents    Event[]

  @@map("users")
}

// ─── Family ───────────────────────────────────────────

model Family {
  id        String   @id @default(uuid())
  name      String
  currency  String   @default("PLN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       FamilyMember[]
  categories    Category[]
  tagGroups     TagGroup[]
  templates     Template[]
  bills         Bill[]
  receipts      Receipt[]
  fixedExpenses FixedExpense[]
  savingsGoals  SavingsGoal[]
  stores        Store[]
  budgets       Budget[]
  events        Event[]

  @@map("families")
}

model FamilyMember {
  id        String     @id @default(uuid())
  userId    String
  familyId  String
  role      FamilyRole @default(MEMBER)
  nickname  String?
  createdAt DateTime   @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([userId, familyId])
  @@map("family_members")
}

// ─── Categories ───────────────────────────────────────

model Category {
  id        String   @id @default(uuid())
  familyId  String
  name      String
  color     String   @default("#2ECC71")
  icon      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([familyId, name])
  @@map("categories")
}

// ─── Tag Groups ───────────────────────────────────────

model TagGroup {
  id        String   @id @default(uuid())
  familyId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  tags   Tag[]

  @@unique([familyId, name])
  @@map("tag_groups")
}

model Tag {
  id         String   @id @default(uuid())
  tagGroupId String
  name       String
  color      String   @default("#2ECC71")
  icon       String?
  imageUrl   String?  @db.Text
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tagGroup TagGroup @relation(fields: [tagGroupId], references: [id], onDelete: Cascade)
  billTags BillTag[]
  receiptTags ReceiptTag[]

  @@unique([tagGroupId, name])
  @@map("tags")
}

// ─── Schema Builder ───────────────────────────────────
// Architecture Decision: JSONB for dynamic schemas.
// columns is IColumnDefinition[] stored as JSONB:
// {
//   id: string, name: string,
//   type: 'text'|'number'|'date'|'checkbox'|'select'|'tags'|'currency'|'person'|'tag_group',
//   required: boolean, width?: number,
//   options?: string[], currencyOptions?: string[],
//   defaultBehavior: 'empty'|'today'|'copy_previous'|'last_used'|'current_user'|'checked'|'unchecked',
//   defaultValue?: string,  // e.g. specific date for 'date' type
//   tagGroupId?: string,    // for 'tag_group' type
//   defaultTagId?: string   // default tag in tag_group
// }
// This avoids EAV complexity while giving full flexibility.
// GIN indexes on JSONB enable efficient querying.

model Template {
  id          String   @id @default(uuid())
  familyId    String
  createdById String
  name        String
  description String?
  icon        String?
  columns     Json     // IColumnDefinition[]
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  family    Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  createdBy User             @relation(fields: [createdById], references: [id])
  records   TemplateRecord[]

  @@map("templates")
}

model TemplateRecord {
  id         String   @id @default(uuid())
  templateId String
  data       Json     // { [columnId]: value }
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, createdAt])
  @@map("template_records")
}

// ─── Bills ────────────────────────────────────────────

enum PaymentType {
  MANUAL
  AUTO_PAY
  DIRECT_DEBIT
}

model Bill {
  id                String      @id @default(uuid())
  familyId          String
  name              String
  amount            Decimal     @db.Decimal(12, 2)
  currency          String      @default("PLN")
  dueDay            Int         // day of month (1-31)
  frequency         Frequency   @default(MONTHLY)
  categoryId        String?
  notes             String?
  isActive          Boolean     @default(true)
  paymentType       PaymentType @default(MANUAL)
  autoCreateExpense Boolean     @default(false)
  reminderDays      Int         @default(3) // days before due to remind
  budgetLimit       Decimal?    @db.Decimal(12, 2) // alert threshold
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  family   Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  payments BillPayment[]
  tags     BillTag[]

  @@map("bills")
}

model BillPayment {
  id      String   @id @default(uuid())
  billId  String
  amount  Decimal  @db.Decimal(12, 2)
  paidAt  DateTime @default(now())
  dueDate DateTime
  notes   String?

  bill Bill @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId, dueDate])
  @@map("bill_payments")
}

model BillTag {
  id     String @id @default(uuid())
  billId String
  tagId  String

  bill Bill @relation(fields: [billId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([billId, tagId])
  @@map("bill_tags")
}

// ─── Receipts ─────────────────────────────────────────

model Receipt {
  id          String   @id @default(uuid())
  familyId    String
  userId      String
  storeId     String?
  billId      String?
  description String
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("PLN")
  date        DateTime
  categoryId  String?
  personId    String?
  imageUrl    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  family Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id])
  store  Store?        @relation(fields: [storeId], references: [id], onDelete: SetNull)
  items  ReceiptItem[]
  tags   ReceiptTag[]

  @@index([familyId, date])
  @@map("receipts")
}

model ReceiptItem {
  id         String  @id @default(uuid())
  receiptId  String
  name       String
  quantity   Decimal @db.Decimal(10, 3) @default(1)
  unitPrice  Decimal @db.Decimal(12, 2)
  total      Decimal @db.Decimal(12, 2)
  categoryId String?

  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([receiptId])
  @@map("receipt_items")
}

model ReceiptTag {
  id        String @id @default(uuid())
  receiptId String
  tagId     String

  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([receiptId, tagId])
  @@map("receipt_tags")
}

// ─── Stores ──────────────────────────────────────────

model Store {
  id                String   @id @default(uuid())
  familyId          String
  name              String
  defaultCategoryId String?
  icon              String?
  address           String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  family   Family    @relation(fields: [familyId], references: [id], onDelete: Cascade)
  receipts Receipt[]

  @@unique([familyId, name])
  @@map("stores")
}

// ─── Budgets ─────────────────────────────────────────

model Budget {
  id         String   @id @default(uuid())
  familyId   String
  name       String
  month      Int      // 1-12
  year       Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  family     Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  categories BudgetCategory[]

  @@unique([familyId, month, year])
  @@map("budgets")
}

model BudgetCategory {
  id         String  @id @default(uuid())
  budgetId   String
  categoryId String
  limitAmount Decimal @db.Decimal(12, 2)

  budget Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@unique([budgetId, categoryId])
  @@map("budget_categories")
}

// ─── Fixed Expenses ───────────────────────────────────

model FixedExpense {
  id         String    @id @default(uuid())
  familyId   String
  name       String
  amount     Decimal   @db.Decimal(12, 2)
  currency   String    @default("PLN")
  frequency  Frequency @default(MONTHLY)
  dayOfMonth Int?
  startDate  DateTime
  endDate    DateTime?
  categoryId String?
  personId   String?
  notes      String?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@map("fixed_expenses")
}

// ─── Savings ──────────────────────────────────────────

model SavingsGoal {
  id           String    @id @default(uuid())
  familyId     String
  name         String
  targetAmount Decimal   @db.Decimal(12, 2)
  currency     String    @default("PLN")
  deadline     DateTime?
  icon         String?
  color        String    @default("#2ECC71")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  family   Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  deposits SavingsDeposit[]

  @@map("savings_goals")
}

model SavingsDeposit {
  id        String   @id @default(uuid())
  goalId    String
  userId    String
  amount    Decimal  @db.Decimal(12, 2)
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())

  goal SavingsGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id])

  @@map("savings_deposits")
}

// ─── Events ──────────────────────────────────────────

enum EventStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum EventItemStatus {
  PENDING
  BOUGHT
  SKIPPED
}

enum TodoPriority {
  LOW
  MEDIUM
  HIGH
}

model Event {
  id          String      @id @default(uuid())
  familyId    String
  createdById String
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime?
  budgetLimit Decimal?    @db.Decimal(12, 2)
  currency    String      @default("PLN")
  color       String      @default("#3B82F6")
  icon        String?
  location    String?
  status      EventStatus @default(PLANNED)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  family    Family         @relation(fields: [familyId], references: [id], onDelete: Cascade)
  createdBy User           @relation(fields: [createdById], references: [id])
  items     EventItem[]
  todos     EventTodo[]
  notes     EventNote[]
  expenses  EventExpense[]

  @@index([familyId, startDate])
  @@map("events")
}

model EventItem {
  id             String          @id @default(uuid())
  eventId        String
  name           String
  quantity       Decimal         @db.Decimal(10, 3) @default(1)
  estimatedPrice Decimal?        @db.Decimal(12, 2)
  actualPrice    Decimal?        @db.Decimal(12, 2)
  categoryId     String?
  assignedToId   String?
  status         EventItemStatus @default(PENDING)
  notes          String?
  sortOrder      Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_items")
}

model EventTodo {
  id           String       @id @default(uuid())
  eventId      String
  title        String
  description  String?
  assignedToId String?
  dueDate      DateTime?
  priority     TodoPriority @default(MEDIUM)
  isCompleted  Boolean      @default(false)
  sortOrder    Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_todos")
}

model EventNote {
  id        String   @id @default(uuid())
  eventId   String
  title     String
  content   String   @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_notes")
}

model EventExpense {
  id         String   @id @default(uuid())
  eventId    String
  receiptId  String?
  name       String
  amount     Decimal  @db.Decimal(12, 2)
  currency   String   @default("PLN")
  date       DateTime
  categoryId String?
  personId   String?
  notes      String?
  createdAt  DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_expenses")
}
